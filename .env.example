# ═══════════════════════════════════════════════════════════════════════════
#  jts-web-app — переменные окружения по трём границам.
#  СЕКРЕТЫ (ключи) НИКОГДА не идут с префиксом VITE_ — иначе Vite вошьёт их в
#  публичный браузерный бандл и любой посетитель их украдёт. Секреты живут
#  только в серверном env (Vercel Functions) и в env LiveKit-агента.
# ═══════════════════════════════════════════════════════════════════════════

# ── SERVER: Vercel serverless (/api) — секреты, в браузер НЕ попадают ─────────
# Прописать в Vercel → Project → Settings → Environment Variables.
ANTHROPIC_API_KEY=            # мозг тьютора (Claude Haiku 4.5 + caching)
LIVEKIT_API_KEY=             # выдача токена + подпись webhook
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://<project>.livekit.cloud
DATABASE_URL=                # Neon — учёт минут (лимит 10/день, 300/мес)
# VOICE_BRAIN_MODEL=claude-haiku-4-5-20251001   # override модели мозга (опц.)

# ── LIVEKIT AGENT: отдельный деплой на LiveKit Cloud (папка agent/) ───────────
# Прописать в env агента на LiveKit Cloud, НЕ в Vercel.
# AZURE_SPEECH_KEY=          # TTS (Azure Neural — заменил ElevenLabs)
# AZURE_SPEECH_REGION=       # напр. eastus
# SONIOX_API_KEY=            # STT
# GEMINI_API_KEY=            # fallback / transcribe
# VOICE_STACK=cascade        # обязательно cascade (не gemini-live)
# JTS_API_URL=https://<vercel-deploy>   # агент → /api/voice/brain этого проекта
# AZURE_TTS_VOICE_OVERRIDE=  # форсировать один голос (отладка)

# ── CLIENT: Vite (VITE_ префикс → в браузере, ТОЛЬКО несекретное) ─────────────
VITE_API_URL=https://dev-server.justtostudy.kz   # бэкенд авторизации (api.js)
# Токен-эндпоинт зовётся same-origin (/api/livekit/token) — отдельный VITE не нужен.
