# ═══════════════════════════════════════════════════════════════════════════
#  jts-web-app (Next.js) — переменные окружения по трём границам.
#  СЕКРЕТЫ (ключи) НИКОГДА не идут с префиксом NEXT_PUBLIC_ — иначе Next вошьёт
#  их в публичный браузерный бандл и любой посетитель их украдёт. Секреты живут
#  только в серверном env (Next route-handlers) и в env LiveKit-агента.
# ═══════════════════════════════════════════════════════════════════════════

# ── SERVER: Next route-handlers (src/app/api) — секреты, в браузер НЕ попадают ─
# Прописать в Vercel → Project → Settings → Environment Variables.
ANTHROPIC_API_KEY=            # мозг тьютора (Claude Haiku 4.5 + caching) + оценка IELTS (Sonnet)
LIVEKIT_API_KEY=             # выдача токена + подпись webhook
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://<project>.livekit.cloud
DATABASE_URL=                # Neon — учёт минут (лимит 10/день, 300/мес) + попытки IELTS
# VOICE_BRAIN_MODEL=claude-haiku-4-5-20251001   # override модели мозга (опц.)
# ANTHROPIC_MODEL=claude-sonnet-5               # override модели оценки IELTS (опц.)

# ── IELTS (src/app/api/ielts/*) — всё опционально, каждая часть деградирует сама ─
# Без ANTHROPIC_API_KEY: Writing/Speaking отдают демо-band, помеченный «демо».
# Listening/Reading считаются по ключу ответов и не требуют ключей вообще.
# AZURE_SPEECH_KEY=          # Speaking: произношение (Pronunciation Assessment)
# AZURE_SPEECH_REGION=       #   + распознавание речи. Тот же ключ, что у агента ниже.
#                            #   Без него: произношение = мок 70/100, транскрипта нет.
# ELEVENLABS_API_KEY=        # Listening: озвучка скриптов. Без него — браузерный TTS.
# ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku   # «Lily» (опц.)
# ELEVENLABS_MODEL=eleven_flash_v2_5         # (опц.)
# ELEVENLABS_SPEED=0.9                       # (опц.)

# ── LIVEKIT AGENT: отдельный деплой на LiveKit Cloud (папка agent/) ───────────
# Прописать в env агента на LiveKit Cloud, НЕ в Vercel.
# AZURE_SPEECH_KEY=          # TTS (Azure Neural — заменил ElevenLabs)
#                            # NB: тот же ключ нужен серверу Next для IELTS Speaking —
#                            # там он читается из env Vercel, а не отсюда.
# AZURE_SPEECH_REGION=       # напр. eastus
# SONIOX_API_KEY=            # STT
# GEMINI_API_KEY=            # fallback / transcribe
# VOICE_STACK=cascade        # обязательно cascade (не gemini-live)
# JTS_API_URL=https://<vercel-deploy>   # агент → /api/voice/brain этого проекта
# AZURE_TTS_VOICE_OVERRIDE=  # форсировать один голос (отладка)

# ── CLIENT: Next public (NEXT_PUBLIC_ префикс → в браузере, ТОЛЬКО несекретное) ─
NEXT_PUBLIC_API_URL=https://dev-server.justtostudy.kz   # бэкенд авторизации (единый источник: src/config/backend.js)
# В ПРОДЕ обязательно переопределить на prod-бэкенд, иначе живые регистрации
# молча уходят в dev-базу. Сервер может отдельно задать BACKEND_URL (server-only,
# без NEXT_PUBLIC_): # BACKEND_URL=https://<prod-backend>
# Google Sign-In: OAuth Web Client ID (Google Cloud Console → Credentials).
# Не секрет (это публичный идентификатор). Пусто = кнопка Google неактивна.
# Тот же ID должен стоять в GOOGLE_OAUTH_CLIENT_ID на бэкенде.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=1234567890-abc.apps.googleusercontent.com
# NEXT_PUBLIC_SCENARIOS_NO_LOCK=1   # открыть ВСЕ сценарии Тьютора, минуя цепочку
#                            # (магазин после интервью, врач после магазина).
#                            # Для локальных тестов — в проде не ставить.
# Токен-эндпоинт зовётся same-origin (/api/livekit/token) — отдельная переменная не нужна.

# Сервисный ключ для голосового агента (см. agent/). Сгенерировать:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=
